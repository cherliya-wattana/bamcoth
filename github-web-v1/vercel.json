{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/presentation-summary/pdf.js": {
      "includeFiles": "fonts/**",
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
